[flake8]
max-line-length = 88
extend-ignore = E203, W503
# fix(#5): scope flake8 to canonical src package; exclude legacy shim during cleanup
filename = src/junior_apogee/*.py, src/junior_apogee/**/*.py
per-file-ignores =
    # Legacy compatibility shim — suppress all warnings until retired in v1.0.0
    junior_apogee_app/*.py: F401, F811, E501, W
    tests/*: S101
